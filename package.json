{
  "name": "bkio",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "dev": "bun --filter @bkio/frontend dev",
    "build": "bun run build:api && bun run build:frontend",
    "build:api": "bun --filter @bkio/api tsc",
    "build:frontend": "bun --filter @bkio/frontend build",
    "deploy": "bun run build && wrangler deploy",
    "test": "bun --parallel --filter '*' test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@bkio/tsconfig": "workspace:*",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "typescript": "catalog:",
    "wrangler": "^4.71.0"
  }
}
