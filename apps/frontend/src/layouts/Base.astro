---
import '@/styles/global.css'
import { Header } from '@/components/Header'
import { Footer } from '@/components/Footer'
import { getAlternateLocale, localizePath, parseLocalizedPath } from '@/lib/routes'

interface Props {
  title?: string
  description?: string
  locale: 'en' | 'zh'
  noindex?: boolean
  detectLocale?: boolean
}

const { title = 'BK', description, locale, noindex = false, detectLocale = false } = Astro.props
const siteName = 'BK'
const siteUrl = Astro.site ?? 'https://bk.io'
const { path } = parseLocalizedPath(Astro.url.pathname)
const canonicalUrl = new URL(localizePath(locale, path), siteUrl)
const altLocale = getAlternateLocale(locale)
const altUrl = new URL(localizePath(altLocale, path), siteUrl)
const xDefaultUrl = new URL(localizePath('en', path), siteUrl)
const fullTitle = title === siteName ? siteName : `${title} - ${siteName}`
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="alternate" hreflang={altLocale} href={altUrl.href} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl.href} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl.href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={locale === 'zh' ? 'en_US' : 'zh_CN'} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <script is:inline>
;(function () {
  const t = localStorage.getItem('bkio-theme')
  const dark =
    t === 'dark' ||
    (t !== 'light' && matchMedia('(prefers-color-scheme: dark)').matches)
  if (dark)
    document.documentElement.classList.add('dark')
})()
</script>
    {detectLocale && (
      <script is:inline>
;(function () {
  const saved = localStorage.getItem('bkio-locale')
  const locale = saved === 'zh' ? 'zh' : (saved === 'en' ? null : (navigator.language.startsWith('zh') ? 'zh' : null))
  if (locale === 'zh')
    window.location.replace('/zh/')
})()
</script>
    )}
  </head>
  <body>
    <main class="relative min-h-screen overflow-x-clip">
      <Header locale={locale} client:load />

      <slot />

      <Footer locale={locale} client:load />
    </main>
  </body>
</html>
