---
import ToolDirectoryPage from '@/components/ToolDirectoryPage.astro'
import { getTranslations } from '@/i18n'
import { getToolsJson, txt } from '@/lib/content'

export function getStaticPaths() {
  const toolsData = getToolsJson()
  return toolsData.categories.map(category => ({
    params: { locale: 'zh', category: category.key },
  }))
}

const locale = 'zh' as const
const categoryKey = Astro.params.category!
const t = getTranslations(locale)
const toolsData = getToolsJson()
const categoryObj = toolsData.categories.find(item => item.key === categoryKey)
const categoryLabel = categoryObj ? txt(categoryObj, locale) : categoryKey
---

<ToolDirectoryPage locale={locale} metaTitle={`${categoryLabel} - ${t.hero.title}`} initialCategory={categoryKey} />
