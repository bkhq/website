---
import Base from '@/layouts/Base.astro'
import { getTranslations } from '@/i18n'
import type { Locale } from '@/i18n'
import { renderMarkdown } from '@/lib/content'
import { GithubPrButton } from '@/components/GithubPrButton'

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'zh' } }]
}

const locale = Astro.params.locale as Locale
const t = getTranslations(locale)

const content: Record<Locale, string> = {
  en: String.raw`
## Quick Submit

Open an Issue with the tool URL if you want AI to draft the content for you.

[Submit via Issue вҶ’](https://github.com/bkhq/website/issues/new?template=quick-submit.yml&title=%5BSubmit%5D+Tool+Name)

If you want to add a tool manually, start from the [Template Guide вҶ’](/template).

## Manual Submit

```bash
# 1. Fork the repo on GitHub
# 2. Clone your fork
# 3. Add content/<your-slug>/
# 4. Register the slug in content/list.json
# 5. Commit, push, and open a Pull Request

git clone https://github.com/<your-username>/website.git
cd website
mkdir -p content/my-tool
```

## Minimum Structure

```text
content/
в”ңв”Җв”Җ list.json
в””в”Җв”Җ my-tool/
    в”ңв”Җв”Җ meta.json
    в”ңв”Җв”Җ en.index.md
    в”ңв”Җв”Җ zh.index.md
    в”ңв”Җв”Җ en.installation.md
    в”ңв”Җв”Җ zh.installation.md
    в”ңв”Җв”Җ en.configuration.md
    в”ңв”Җв”Җ zh.configuration.md
    в”ңв”Җв”Җ en.data.md
    в”ңв”Җв”Җ zh.data.md
    в”ңв”Җв”Җ en.faq.md
    в””в”Җв”Җ zh.faq.md
```

## Notes

- Keep the slug URL-safe. Use `zzci-chrome`, not `zzci/chrome`.
- Put display names such as `zzci/chrome` in `meta.json`.
- Use placeholders like `[[agent-browser]]` or `[[bkd/data|Data & Storage]]` for internal links. They are localized automatically.
- Add `relatedTools` in `meta.json` if this tool should link to another entry.
`,
  zh: String.raw`
## еҝ«йҖҹжҠ•зЁҝ

еҰӮжһңдҪ еҸӘжғідёўдёҖдёӘе·Ҙе…·й“ҫжҺҘпјҢи®© AI её®дҪ иө·иҚүеҶ…е®№пјҢеҸҜд»ҘзӣҙжҺҘжҸҗ IssueгҖӮ

[йҖҡиҝҮ Issue жҸҗдәӨ вҶ’](https://github.com/bkhq/website/issues/new?template=quick-submit.yml&title=%5B%E6%8F%90%E4%BA%A4%5D+%E5%B7%A5%E5%85%B7%E5%90%8D%E7%A7%B0)

еҰӮжһңдҪ жғіиҮӘе·ұж·»еҠ е·Ҙе…·пјҢе…ҲзңӢ [жЁЎжқҝиҜҙжҳҺ вҶ’](/template)гҖӮ

## жүӢеҠЁжҸҗдәӨ

```bash
# 1. еңЁ GitHub дёҠ Fork д»“еә“
# 2. е…ӢйҡҶдҪ зҡ„ Fork
# 3. ж·»еҠ  content/<your-slug>/
# 4. еңЁ content/list.json йҮҢжіЁеҶҢ slug
# 5. жҸҗдәӨгҖҒжҺЁйҖҒе№¶еҲӣе»ә Pull Request

git clone https://github.com/<your-username>/website.git
cd website
mkdir -p content/my-tool
```

## жңҖе°Ҹзӣ®еҪ•з»“жһ„

```text
content/
в”ңв”Җв”Җ list.json
в””в”Җв”Җ my-tool/
    в”ңв”Җв”Җ meta.json
    в”ңв”Җв”Җ en.index.md
    в”ңв”Җв”Җ zh.index.md
    в”ңв”Җв”Җ en.installation.md
    в”ңв”Җв”Җ zh.installation.md
    в”ңв”Җв”Җ en.configuration.md
    в”ңв”Җв”Җ zh.configuration.md
    в”ңв”Җв”Җ en.data.md
    в”ңв”Җв”Җ zh.data.md
    в”ңв”Җв”Җ en.faq.md
    в””в”Җв”Җ zh.faq.md
```

## иҜҙжҳҺ

- slug еҝ…йЎ»жҳҜ URL е®үе…Ёж јејҸпјҢеғҸ `zzci/chrome` иҝҷж ·зҡ„еұ•зӨәеҗҚеә”иҜҘеҶҷиҝӣ `meta.json`пјҢslug еҲҷз”Ё `zzci-chrome`гҖӮ
- ж–ҮжЎЈйҮҢзҡ„з«ҷеҶ…й“ҫжҺҘз”Ё `[[agent-browser]]` жҲ– `[[bkd/data|ж•°жҚ®иҜҙжҳҺ]]` иҝҷз§ҚеҚ дҪҚз¬ҰеҶҷжі•пјҢжёІжҹ“ж—¶дјҡиҮӘеҠЁжҢүиҜӯиЁҖеҲҮжҚўгҖӮ
- еҰӮжһңдёӨдёӘе·Ҙе…·йңҖиҰҒдә’зӣёжҺЁиҚҗпјҢеҸҜд»ҘеңЁ `meta.json` йҮҢж·»еҠ  `relatedTools`гҖӮ
`,
}

const htmlContent = await renderMarkdown(content[locale], locale)
---

<Base title={t.submit.title} description={t.submit.description} locale={locale}>
  <section class="relative z-10">
    <div class="mx-auto w-full max-w-5xl px-4 pb-14 pt-8 sm:px-6 sm:pt-10 lg:px-8">
      <div class="pb-8 text-center">
        <h1 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
          {t.submit.title}
        </h1>
        <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground sm:text-base">
          {t.submit.description}
        </p>
        <div class="mt-5 flex justify-center">
          <GithubPrButton locale={locale} client:load />
        </div>
      </div>

      <div class="flex items-start justify-center">
        <article class="prose-article rounded-xl bg-white p-6 shadow-sm dark:bg-white/[0.03] sm:p-8" set:html={htmlContent} />
      </div>
    </div>
  </section>
</Base>
