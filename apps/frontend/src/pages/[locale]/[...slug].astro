---
import ToolDetailPage from '@/components/ToolDetailPage.astro'
import { getToolDocSlugs, getToolsJson } from '@/lib/content'

export function getStaticPaths() {
  const toolsData = getToolsJson()
  const paths: { params: { locale: string, slug: string } }[] = []

  for (const item of toolsData.list) {
    paths.push({ params: { locale: 'zh', slug: item.slug } })

    const docSlugs = getToolDocSlugs(item.slug)
    for (const docSlug of docSlugs) {
      if (docSlug !== 'index') {
        paths.push({ params: { locale: 'zh', slug: `${item.slug}/${docSlug}` } })
      }
    }
  }

  return paths
}

const slug = Astro.params.slug!
---

<ToolDetailPage locale="zh" slug={slug} />
