---
import ToolDetailPage from '@/components/ToolDetailPage.astro'
import { getToolDocSlugs, getToolsJson } from '@/lib/content'
import { isReservedRootSlug } from '@/lib/routes'

export function getStaticPaths() {
  const toolsData = getToolsJson()
  const paths: { params: { slug: string } }[] = []

  for (const item of toolsData.list) {
    if (isReservedRootSlug(item.slug))
continue

    paths.push({ params: { slug: item.slug } })

    const docSlugs = getToolDocSlugs(item.slug, toolsData)
    for (const docSlug of docSlugs) {
      if (docSlug !== 'index') {
        paths.push({ params: { slug: `${item.slug}/${docSlug}` } })
      }
    }
  }

  return paths
}

const slug = Astro.params.slug!
---

<ToolDetailPage locale="en" slug={slug} />
