---
import Base from '@/layouts/Base.astro'
---

<Base title="404" locale="en" noindex>
  <section class="relative z-10">
    <div class="mx-auto flex w-full max-w-5xl flex-col items-center px-4 py-32 text-center sm:px-6 lg:px-8">
      <h1 class="text-6xl font-semibold tracking-tight text-foreground sm:text-8xl">404</h1>
      <p class="mt-4 text-base text-muted-foreground">
        This page doesn't exist yet. Maybe it should?
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 rounded-full border border-border/60 px-4 py-2 text-sm text-foreground/70 transition-colors hover:border-border hover:text-foreground"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back to Home
        </a>
        <a
          href="/sys/submit"
          class="inline-flex items-center gap-1.5 rounded-full bg-foreground px-4 py-2 text-sm text-background transition-colors hover:bg-foreground/90"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          Submit a Tool
        </a>
      </div>
    </div>
  </section>
</Base>
