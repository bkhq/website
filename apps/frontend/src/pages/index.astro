---
// Root renders English by default (good for SEO), redirects to /zh/ if browser is Chinese
import Base from '@/layouts/Base.astro'
import { ToolSearch } from '@/components/ToolSearch'
import { getTranslations } from '@/i18n'
import { getToolsJson, getToolMeta, getToolBadge, getToolTags, resolveToolLogo, txt } from '@/lib/content'

const locale = 'en' as const
const t = getTranslations(locale)
const toolsData = getToolsJson()

const toolItems = toolsData.list
  .sort((a, b) => (a.order ?? Infinity) - (b.order ?? Infinity))
  .map((item) => {
    const meta = getToolMeta(item.slug)
    const logo = resolveToolLogo(item.slug, item.logo)
    const title = txt(meta.title, locale)
    return {
      slug: item.slug,
      category: item.category,
      badge: getToolBadge(toolsData, item.category, locale),
      logo: logo.type === 'icon' ? item.logo! : logo.type === 'svg' ? 'custom' : '',
      logoSvg: logo.type === 'svg' ? logo.content : undefined,
      order: item.order,
      title,
      description: txt(meta.description, locale),
      tags: getToolTags(toolsData, item.tags ?? [], locale),
    }
  })

const categories = toolsData.categories.map((cat) => ({
  key: cat.key,
  label: txt(cat, locale),
}))

const allTags = toolsData.tags.map((tag) => ({
  key: tag.key,
  label: txt(tag, locale),
}))
---

<Base title={t.hero.title} description={t.hero.subtitle} locale={locale} detectLocale>
  <section class="relative z-10">
    <div class="mx-auto flex w-full max-w-5xl flex-col items-center px-4 pb-8 pt-8 text-center sm:px-6 sm:pt-10 lg:px-8">
      <h1 class="max-w-4xl text-4xl font-semibold tracking-[-0.05em] text-foreground sm:text-5xl lg:text-6xl">
        {t.hero.title}
      </h1>

      <p class="mt-3 max-w-2xl text-[15px] leading-6 text-muted-foreground sm:text-base">
        {t.hero.subtitle}
      </p>

      <ToolSearch
        client:load
        locale={locale}
        tools={toolItems}
        categories={categories}
        allTags={allTags}
        translations={{
          searchPlaceholder: t.hero.searchPlaceholder,
          all: t.categories.all,
          view: t.card.view,
          noResults: t.card.noResults,
          tags: t.card.tags,
          pagination: t.pagination,
        }}
      />
    </div>
  </section>
</Base>
